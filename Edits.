#READING IN THE VENDOR DATA FILE INTO PYTHON
def load_data(filename):
    data = []
    try:
        with open(filename, "r") as file:
            for line in file:
                row = line.strip().split(",")
                if len(row) != 7:
                    continue
           
                record = {
                     "id": row[0],
                     "name": row[1],
                     "week": int(row[2]),
                     "vegan": int(row[3]),
                     "meat": int(row[4]),
                     "onions": float(row[5]),
                     "ketchup": float(row[6])
                  }
        data.append(record)
    except FileNotFoundError:
        print("Error: File not found.")
    except ValueError:
        print("Error: Data format issue in file")
    return data


#LINEAR SEARCHING THROUGH UNSORTED DATA

def linear_search_sorted(data, target):
    for item in data:
        if item["id"] == target:
            return item
        elif item["id"] > target:
            break
    return None

# LINEAR SEARCH THROUFH SORTED DATA

def linear_search_sorted(data, target):
    for item in data:
        if item["id"] == target:
            return item
        elif item["id"] > target:
            break
    return None


# SEARCH THE DATA USING A BINARY SEARCH

def binary_search(data, target): #Initialises the boundaries
    low = 0
    high = len(data) - 1


    while low <= high: #Continues searching as long as there's an element
        mid = (low + high) // 2 #The formula utilised for it


        if data[mid]["id"] == target: #Check if the searching element is equal to the target
            return data[mid]
        elif data[mid]["id"] < target: 
            low = mid + 1 #If middle is lower than target discard left
        else:
            high = mid - 1 #If middle is higher than target discard right




# SEARCH THE DATA USING BUBBLE SORT

def bubble_sort(data): #Intialises the function
    arr = data.copy() #Makes a new copy to add the sorted data
    n = len(arr) #Counts the array


    for i in range(n): # Loops the entire code
        for j in range(0, n-i-1): #Comparing thelast element
            if arr[j]["id"] > arr[j+1]["id"]: # Compares the 'id' and its adjacent value
                arr[j], arr[j+1] = arr[j+1], arr[j] #If the left is bigger it swaps it


    return arr

#SORT THE DATA USING QUICK SORT

def quick_sort(data):  #To define a function
     if len(data) <=1: #If the data is less than one
          return data  #Return the data
     pivot = data[0]   #Used to sort the array
     left = [ x for x in data[1:] if ["id"] <= pivot["id"]] #if the left value[id] is smaller than the pivot it puts the value on the left side of the pivot
     right = [ x for x in data[1:] if ["id"] > pivot["id"]] #And if the right value[id] is bigger than the pivot it'll put the value on the right side of it
     return quick_sort(left) + [pivot] + quick_sort(right) #It does the same thing and repeats the steps until it's sorted in ascended order


