#READING IN THE VENDOR DATA FILE INTO PYTHON
def load_data(filename):
     data = []

     file = open(filename, "r")
     lines = file.readlines()
     file.close()

     for line in lines:
          parts = line.strip().split(",")

          row = [
               parts[0],
               parts[1],
               int(parts[3]),
               int(parts[4]),
               float(parts[5]),
               float(parts[6]),
          ]
          data.append(row)

#LINEAR SEARCHING THROUGH UNSORTED DATA

def linear_search_unsorted(data,targetVal):
     #Searching through unsorted dataset
     for row in data :
          if row[1].lower() == targetVal.lower():
               return row
     return None 

# LINEAR SEARCH THROUFH SORTED DATA

def linear_search_sorted(data,targetVal):
     #Now searching through the sorted data
     for row in data:
           if row[1].lower() == targetVal.lower():
                return row
           elif row[1].lower() > targetVal:
                break
     return None  

# SEARCH THE DATA USING A BINARY SEARCH


def binary_search(data,targetVal): #Initialises the high and low boundaries
     low = 0  
     high = len(data) - 1

     while low<= high: # Continues searching as long as the searching has one element
          mid = (low + high) // 2  # Formula to find the middle index of the array
          if data[mid][1].lower() == targetVal.lower(): # Checks if the searching element is equal to the target value
               return data[mid] # Returns the value if the conclusion is true
          elif data[mid][1].lower() < targetVal.lower(): 
               low = mid + 1 # However if the middle value is lower than the target value discard the left
               high = mid - 1 # However if the middle is higher than the the target discard the right

     return None


# SEARCH THE DATA USING BUBBLE SORT

def bubble_sort(data):  #To start a function
     arr = data.copy()  #Creates a seperate copy to save the data
     n = len(arr)       #To count the numbers we have

     for i in range(n): # To keep repeating the step
          for j in range(0, n-i-1): #Checks the numbers in the wrong order
               if arr[j][1] > arr[j+1][1]: #If the left number is bigger it needs to be stopped
                    arr[j], arr[j+1] = arr[j+1], arr[j] # Swaps the numbers so the bigger one goes on the right
     return arr

#SORT THE DATA USING QUICK SORT

def quick_sort(data):  #To define a function
     if len(data) <=1: #If the data is less than one
          return data  #Return the data
     pivot = data[0]   #Used to sort the array
     left = [ x for x in data[1:] if ["id"] <= pivot["id"]] #if the left value[id] is smaller than the pivot it puts the value on the left side of the pivot
     right = [ x for x in data[1:] if ["id"] >= pivot["id"]] #And if the right value[id] is bigger than the pivot it'll put the value on the right side of it
     return quick_sort(left) + [pivot] + quick_sort(right) #It does the same thing and repeats the steps until it's sorted in ascended order


#TIMING FUNCTIONS

def time_searches(data, target):
     sorted_data = quick_sort(data)

