def load_data(filename):
     data = []

     file = open(filename, "r")
     lines = file.readlines()
     file.close()

     for line in lines:
          parts = line.strip().split(",")

          row = [
               parts[0],
               parts[1],
               int(parts[3]),
               int(parts[4]),
               float(parts[5]),
               float(parts[6]),
          ]
          data.append(row)
